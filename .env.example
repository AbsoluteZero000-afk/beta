# ============================================
# QuantEdge Phase 1 — Environment Variables
# ============================================

# --- Alpaca API ---
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex

# --- PostgreSQL + TimescaleDB ---
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_USER=quantedge
POSTGRES_PASSWORD=quantedge_secret_change_me
POSTGRES_DB=quantedge
DATABASE_URL=postgresql://quantedge:quantedge_secret_change_me@timescaledb:5432/quantedge

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- App Settings ---
LOG_LEVEL=INFO
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,SPY,QQQ
SIGNAL_BUFFER_SIZE=200

# --- Slack (Phase 5) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
